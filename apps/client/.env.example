# Copy to .env.local and fill in.
VITE_API_URL=https://declyne-api.YOUR-SUBDOMAIN.workers.dev

# VITE_API_TOKEN is a one-shot migration source only. On first launch the
# client reads this value, writes it into the iOS Keychain via
# capacitor-secure-storage-plugin (or localStorage on web), then ignores
# the env on subsequent launches. To rotate, see docs/runbooks/rotate-api-token.md
# — short version: paste the new value into the in-app Settings -> Token, or
# call clearToken() and reload to fall back through this env again.
VITE_API_TOKEN=paste-the-same-value-you-used-for-wrangler-secret-put-API_TOKEN
