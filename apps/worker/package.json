{
  "name": "@declyne/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "wrangler d1 execute declyne --remote --file=./drizzle/0000_init.sql",
    "db:push:local": "wrangler d1 execute declyne --local --file=./drizzle/0000_init.sql",
    "db:seed": "wrangler d1 execute declyne --local --file=./drizzle/seed.sql"
  },
  "dependencies": {
    "@declyne/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.16"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260504.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wrangler": "^4.87.0"
  }
}
